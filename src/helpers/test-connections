#!/bin/bash

set -euo pipefail

_test_connection() {
  local count=0
  local type="${1}"
  local status

  log_info "Testing ${type} connection..."

  while [ "$count" -lt "$KLOUDKIT_TEST_TIMEOUT" ]; do
    php -f "/checks/test_${type}_connection.php" > /dev/null 2>&1
    status=$?

    if [ "$status" -eq 0 ]; then
      log_info "${type^} connection successful."
      return 0
    fi

    log_info "Waiting on $type connection, retrying... $((KLOUDKIT_TEST_TIMEOUT - count)) seconds left"
    count=$((count + 1))
    sleep 1
  done

  log_error "${type^} connection failed after ${KLOUDKIT_TEST_TIMEOUT}s."
  return 1
}

_test_connections() {
  local tested=0
  local skipped=0
  local failed=0

  declare -A connections=(
    [database]="${KLOUDKIT_TEST_DB:-true}"
    [cache]="${KLOUDKIT_TEST_CACHE:-true}"
    [queue]="${KLOUDKIT_TEST_QUEUE:-false}"
    [redis]="${KLOUDKIT_TEST_REDIS:-false}"
    [s3]="${KLOUDKIT_TEST_S3:-false}"
    [smtp]="${KLOUDKIT_TEST_SMTP:-false}"
  )

  for service in "${!connections[@]}"; do
    if [ "${connections[$service]}" != "true" ]; then
      log_info "Skipping $service connection test."
      skipped=$((skipped + 1))
    else
      if _test_connection "$service"; then
        tested=$((tested + 1))
      else
        tested=$((tested + 1))
        failed=$((failed + 1))
      fi
    fi
  done

  log_info "Connection tests complete: $tested tested, $skipped skipped."

  if [ "$failed" -gt 0 ]; then
    log_error "$failed connection(s) failed."
    exit 1
  fi
}

_test_connections
